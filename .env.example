# ── Content generation (Google Cloud / Vertex AI) ──────────────────────────
# Path to your GCP service account key JSON (needs Vertex AI User role).
# The project id is read from this file automatically.
GOOGLE_APPLICATION_CREDENTIALS=./pips-projects-c27796213f7f.json
# Optional overrides:
# GOOGLE_CLOUD_PROJECT=pips-projects
# GOOGLE_CLOUD_LOCATION=us-central1
# GEMINI_MODEL=gemini-2.5-pro
# VEO_MODEL=veo-3.1-generate-001

# ── YouTube API Credentials ────────────────────────────────────────────────
# Get these from https://console.cloud.google.com/ (see get_youtube_token.py
# for generating the refresh token)
YOUTUBE_API_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_API_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_API_REFRESH_TOKEN=your_youtube_refresh_token_here

# ── Facebook/Instagram API Credentials ─────────────────────────────────────
# Get these from https://developers.facebook.com/
FB_ACCESS_TOKEN=your_facebook_access_token_here
FB_PAGE_ID=your_facebook_page_id_here
IG_PAGE_ID=your_instagram_page_id_here

# ── GitHub Token for Instagram/Facebook Video Hosting ──────────────────────
# Instagram needs a public URL for the video; we host it temporarily in this
# repo. Create a Personal Access Token at https://github.com/settings/tokens
# Required scopes: repo
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=moe-a11y/Pips_Projects

# ── TikTok API Credentials (Optional) ───────────────────────────────────────
# Get these from https://developers.tiktok.com/ (Content Posting API,
# video.publish scope; direct posting requires an audited app)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
